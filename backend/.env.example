# Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com valores reais
# NUNCA commite o arquivo .env

# Banco de Dados (Railway MySQL ou local)
DB_URL=jdbc:mysql://localhost:3306/dragenda_dev?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=sua_senha_aqui

# JWT — gerar com: openssl rand -base64 64
JWT_SECRET=seu_jwt_secret_base64_aqui_minimo_32_caracteres
JWT_EXPIRATION_MS=86400000

# AES-256 — gerar com: openssl rand -hex 32 (64 caracteres hex = 32 bytes)
ENCRYPTION_KEY=sua_chave_aes_256_aqui_64_chars_hex

# CORS — URL do frontend (separar múltiplas origens com vírgula)
APP_FRONTEND_URL=http://localhost:5173

# Seed do Admin Sistema (obrigatório em produção)
ADMIN_SEED_PASSWORD=

# Servidor
SERVER_PORT=8080
